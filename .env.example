# OpenGlaze Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================

BASE_URL=http://localhost:8768
FLASK_ENV=development

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgres://openglaze:password@postgres:5432/openglaze

# =============================================================================
# KRATOS (Auth)
# =============================================================================

KRATOS_PUBLIC_URL=http://kratos:4433
KRATOS_ADMIN_URL=http://kratos:4434
KRATOS_HOOK_KEY=your-secret-key-here

# =============================================================================
# STRIPE (Primary Payment)
# =============================================================================

# Get from https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Price IDs from Stripe Dashboard
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly
STRIPE_PRICE_STUDIO_MONTHLY=price_studio_monthly
STRIPE_PRICE_STUDIO_YEARLY=price_studio_yearly
STRIPE_PRICE_EDUCATION_YEARLY=price_education_yearly

# =============================================================================
# PAYPAL (Alternative Payment)
# =============================================================================

# Get from https://developer.paypal.com/developer/applications
PAYPAL_CLIENT_ID=your_client_id_here
PAYPAL_CLIENT_SECRET=your_client_secret_here
PAYPAL_MODE=sandbox

# =============================================================================
# BTCPAY (Cryptocurrency - Self-Hosted)
# =============================================================================

# Configure at your BTCPay Server instance
BTCPAY_URL=https://your-btcpay-server.com
BTCPAY_STORE_ID=your_store_id
BTCPAY_API_KEY=your_api_key

# =============================================================================
# MANUAL BILLING
# =============================================================================

MANUAL_BILLING_EMAIL=billing@yourdomain.com

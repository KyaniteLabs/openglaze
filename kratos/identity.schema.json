{
  "$id": "https://openglaze.app/schemas/identity.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenGlaze User",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "Email",
          "minLength": 3,
          "maxLength": 320,
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              }
            },
            "verification": {
              "via": "email"
            },
            "recovery": {
              "via": "email"
            }
          }
        },
        "studio_name": {
          "type": "string",
          "title": "Studio Name",
          "maxLength": 100
        },
        "template_id": {
          "type": "string",
          "title": "Starting Template",
          "description": "Which template they started with"
        }
      },
      "required": ["email"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
